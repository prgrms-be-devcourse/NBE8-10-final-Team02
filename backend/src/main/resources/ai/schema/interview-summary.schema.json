{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "shortSummary",
    "strengths",
    "weaknesses",
    "nextActions",
    "qualityFlags"
  ],
  "additionalProperties": false,
  "properties": {
    "shortSummary": {
      "type": "string",
      "minLength": 1
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 3
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 3
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 3
    },
    "qualityFlags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
