{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "answers",
    "qualityFlags"
  ],
  "additionalProperties": false,
  "properties": {
    "answers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "questionOrder",
          "questionText",
          "answerText",
          "usedEvidenceKeys",
          "qualityFlags"
        ],
        "additionalProperties": false,
        "properties": {
          "questionOrder": {
            "type": "integer",
            "minimum": 1
          },
          "questionText": {
            "type": "string",
            "minLength": 1
          },
          "answerText": {
            "type": "string",
            "minLength": 1
          },
          "usedEvidenceKeys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "qualityFlags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "qualityFlags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
